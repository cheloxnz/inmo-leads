{% comment %}
  InmoBot - Header Section para Shopify
  Copiar este código en: Online Store > Themes > Edit code > Sections > Crear nueva sección
  Nombre: inmobot-header.liquid
{% endcomment %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Work+Sans:wght@600;700&display=swap');

  .inmobot-header {
    background: {{ section.settings.bg_color }};
    {% if section.settings.sticky %}
    position: sticky;
    top: 0;
    z-index: 1000;
    {% endif %}
    border-bottom: 1px solid rgba(255,255,255,0.08);
    font-family: 'Inter', -apple-system, sans-serif;
  }

  .inmobot-header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.85rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .inmobot-header-brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
  }

  .inmobot-header-logo {
    width: {{ section.settings.logo_size }}px;
    height: {{ section.settings.logo_size }}px;
    border-radius: 10px;
    object-fit: contain;
  }

  .inmobot-header-name {
    font-family: 'Work Sans', 'Inter', sans-serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.01em;
  }

  .inmobot-header-name span {
    color: {{ section.settings.accent_color }};
  }

  .inmobot-header-nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .inmobot-header-links {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .inmobot-header-links a {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
    letter-spacing: 0.01em;
  }

  .inmobot-header-links a:hover {
    color: #ffffff;
  }

  .inmobot-header-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: {{ section.settings.accent_color }};
    color: #ffffff !important;
    padding: 0.55rem 1.25rem;
    border-radius: 8px;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    border: none;
    cursor: pointer;
  }

  .inmobot-header-cta:hover {
    background: {{ section.settings.accent_hover }};
    transform: translateY(-1px);
    color: #ffffff !important;
  }

  .inmobot-header-cta svg {
    width: 16px;
    height: 16px;
  }

  /* Mobile menu */
  .inmobot-menu-toggle {
    display: none;
    background: none;
    border: none;
    color: #ffffff;
    cursor: pointer;
    padding: 0.5rem;
  }

  .inmobot-menu-toggle svg {
    width: 24px;
    height: 24px;
  }

  @media (max-width: 768px) {
    .inmobot-header-inner {
      padding: 0.75rem 1.25rem;
    }

    .inmobot-menu-toggle {
      display: block;
    }

    .inmobot-header-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: {{ section.settings.bg_color }};
      flex-direction: column;
      padding: 1.5rem;
      gap: 1.25rem;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .inmobot-header-nav.active {
      display: flex;
    }

    .inmobot-header-links {
      flex-direction: column;
      gap: 1rem;
      width: 100%;
      text-align: center;
    }

    .inmobot-header-links a {
      font-size: 1rem;
      padding: 0.5rem 0;
      display: block;
    }

    .inmobot-header-cta {
      width: 100%;
      justify-content: center;
      padding: 0.75rem;
    }
  }
</style>

<header class="inmobot-header">
  <div class="inmobot-header-inner">
    <a href="{{ section.settings.logo_link }}" class="inmobot-header-brand">
      {% if section.settings.logo_image != blank %}
        <img 
          src="{{ section.settings.logo_image | image_url: width: 200 }}" 
          alt="{{ section.settings.brand_name }}" 
          class="inmobot-header-logo"
          loading="eager"
        >
      {% else %}
        <img 
          src="https://customer-assets.emergentagent.com/job_lead-manager-es/artifacts/l1ys0o2g_ChatGPT%20Image%203%20feb%202026%2C%2009_57_44%20p.m..png" 
          alt="{{ section.settings.brand_name }}" 
          class="inmobot-header-logo"
          loading="eager"
        >
      {% endif %}
      <span class="inmobot-header-name">
        {{ section.settings.brand_name_white }}<span>{{ section.settings.brand_name_accent }}</span>
      </span>
    </a>

    <button class="inmobot-menu-toggle" onclick="this.nextElementSibling.classList.toggle('active')" aria-label="Menu">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>

    <nav class="inmobot-header-nav">
      <ul class="inmobot-header-links">
        {% for block in section.blocks %}
          {% if block.type == 'link' %}
            <li>
              <a href="{{ block.settings.url }}">{{ block.settings.label }}</a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>

      {% if section.settings.cta_text != blank %}
        <a href="{{ section.settings.cta_url }}" class="inmobot-header-cta">
          {% if section.settings.cta_icon == 'play' %}
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3" fill="currentColor" stroke="none"/></svg>
          {% elsif section.settings.cta_icon == 'arrow' %}
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-7-7 7 7-7 7"/></svg>
          {% elsif section.settings.cta_icon == 'lock' %}
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          {% endif %}
          {{ section.settings.cta_text }}
        </a>
      {% endif %}
    </nav>
  </div>
</header>

{% schema %}
{
  "name": "InmoBot Header",
  "settings": [
    {
      "type": "header",
      "content": "Marca"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_size",
      "label": "Tamaño del logo (px)",
      "min": 28,
      "max": 56,
      "step": 4,
      "default": 40
    },
    {
      "type": "text",
      "id": "brand_name_white",
      "label": "Nombre (parte blanca)",
      "default": "Inmo"
    },
    {
      "type": "text",
      "id": "brand_name_accent",
      "label": "Nombre (parte color)",
      "default": "Bot"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Nombre completo (alt del logo)",
      "default": "InmoBot"
    },
    {
      "type": "url",
      "id": "logo_link",
      "label": "Link del logo",
      "default": "/"
    },
    {
      "type": "header",
      "content": "Colores"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fondo del header",
      "default": "#0f172a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de acento (botón CTA)",
      "default": "#2563eb"
    },
    {
      "type": "color",
      "id": "accent_hover",
      "label": "Color hover del CTA",
      "default": "#1d4ed8"
    },
    {
      "type": "header",
      "content": "Botón CTA"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto del botón",
      "default": "Acceder"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Link del botón",
      "default": "/account/login"
    },
    {
      "type": "select",
      "id": "cta_icon",
      "label": "Icono del botón",
      "options": [
        { "value": "none", "label": "Sin icono" },
        { "value": "play", "label": "Play" },
        { "value": "arrow", "label": "Flecha" },
        { "value": "lock", "label": "Candado" }
      ],
      "default": "lock"
    },
    {
      "type": "header",
      "content": "Opciones"
    },
    {
      "type": "checkbox",
      "id": "sticky",
      "label": "Header fijo al hacer scroll",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Link de navegación",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Texto",
          "default": "Link"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL",
          "default": "/"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "InmoBot Header",
      "blocks": [
        { "type": "link", "settings": { "label": "Masterclass", "url": "/" } },
        { "type": "link", "settings": { "label": "Módulos", "url": "#modulos" } },
        { "type": "link", "settings": { "label": "Precio", "url": "#precio" } },
        { "type": "link", "settings": { "label": "FAQ", "url": "#faq" } }
      ]
    }
  ]
}
{% endschema %}
